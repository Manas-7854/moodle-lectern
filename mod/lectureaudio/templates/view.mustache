<div class="mod-lectureaudio-container container mt-4" id="lectureaudio-container-{{cmid}}">
    {{#hastranscript}}
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">{{#str}}transcript, mod_lectureaudio{{/str}}</h5>
        </div>
        <div class="card-body text-center">
             <a href="{{transcripturl}}" class="btn btn-lg btn-outline-dark" target="_blank">
                <i class="fa fa-file-text"></i> {{#str}}downloadtranscript, mod_lectureaudio{{/str}}
             </a>
        </div>
    </div>
    {{/hastranscript}}

    {{^hastranscript}}
       <div class="alert alert-info">{{#str}}norecording, mod_lectureaudio{{/str}}</div>
    {{/hastranscript}}

    {{#canrecord}}
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">{{#str}}modulename, mod_lectureaudio{{/str}} - {{#str}}startrecording, mod_lectureaudio{{/str}}</h5>
        </div>
        <div class="card-body text-center">

            <div class="timer-display mb-3" style="font-size: 3rem; font-family: monospace; font-weight: bold;">
                <span id="timer">00:00</span>
            </div>

            <div class="visualizer-container mb-4">
                 <canvas id="audio-visualizer" width="800" height="150" style="width: 100%; height: 150px; border-radius: 4px; background-color: #f8f9fa; border: 1px solid #dee2e6;"></canvas>
            </div>

            <div class="transcript-container mb-4 text-start">
                <label for="liveTranscript" class="form-label font-weight-bold">{{#str}}livetranscript, mod_lectureaudio{{/str}}</label>
                <textarea id="liveTranscript" class="form-control" rows="6" placeholder="{{#str}}transcriptplaceholder, mod_lectureaudio{{/str}}"></textarea>
            </div>

            <div class="controls d-flex gap-3 justify-content-center flex-wrap">
                <button id="startBtn" class="btn btn-danger btn-lg px-4">
                    <i class="fa fa-microphone"></i> {{#str}}record, mod_lectureaudio{{/str}}
                </button>
                <button id="stopBtn" class="btn btn-secondary btn-lg px-4" disabled>
                    <i class="fa fa-stop"></i> {{#str}}stop, mod_lectureaudio{{/str}}
                </button>
                <button id="summarizeBtn" class="btn btn-info btn-lg px-4 text-white" disabled>
                    <i class="fa fa-magic"></i> {{#str}}summarize, mod_lectureaudio{{/str}}
                </button>
                <button id="uploadBtn" class="btn btn-success btn-lg px-4" disabled>
                    <i class="fa fa-save"></i> {{#str}}saveupload, mod_lectureaudio{{/str}}
                </button>
            </div>

            <div id="statusMsg" class="mt-3 text-muted font-weight-bold">{{#str}}readytorecord, mod_lectureaudio{{/str}}</div>
        </div>
    </div>
    {{/canrecord}}

    {{#showsummarysection}}
    <div id="summary-section" class="card shadow mt-4"{{#summaryinitiallyhidden}} style="display:none;"{{/summaryinitiallyhidden}}>
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fa fa-magic"></i> {{#str}}aisummarynotes, mod_lectureaudio{{/str}}</h5>
        </div>
        <div class="card-body text-start">
            <div id="aiSummaryContent" class="p-3" style="font-size: 1.1rem; line-height: 1.6;"></div>
        </div>
    </div>
    {{/showsummarysection}}
</div>
